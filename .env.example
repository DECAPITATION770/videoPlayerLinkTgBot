TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
# Адрес, по которому пользователи открывают ссылки (без слэша в конце):
# локально — http://localhost:8000  или  https://xxxx.ngrok-free.app
PUBLIC_URL=http://localhost:8000
# APP_URL=http://app:8000  # для Docker: бот вызывает API

# Для файлов >20 МБ — получите на https://my.telegram.org → API development tools
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=abcdef...
# TELEGRAM_BOT_API_URL=http://telegram-bot-api:8081
